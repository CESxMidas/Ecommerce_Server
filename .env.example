NODE_ENV=development
PORT=888
API_URL=http://localhost:888
CORS_ORIGIN=http://localhost:5173

# Database
MONGODB_URL="mongodb://user:password@host:27017/ecommerceApp?authSource=admin"

# JWT
JWT_SECRET=dev_ecommerce_jwt_change_in_production
JWT_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_DAYS=30

# Rate limit
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_MAX=30

# Gmail
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Email API for deployed demo on hosts that block SMTP
RESEND_API_KEY=
EMAIL_FROM=

# Google OAuth
GOOGLE_CLIENT_ID=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# VNPay Sandbox
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAYMENT_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_EXCHANGE_RATE=25000
