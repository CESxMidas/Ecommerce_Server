PORT=888
API_URL=http://localhost:888
CORS_ORIGIN=http://localhost:5173

# Database (Chọn 1 trong 2 đường dẫn mong muốn - hiện tại tôi để Atlas Local hoặc Cluster tùy bạn chọn)
MONGODB_URL="mongodb://user:password@host:27017/ecommerceApp?authSource=admin"

# JWT
JWT_SECRET=dev_ecommerce_jwt_change_in_production
JWT_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_DAYS=30

# Rate limit
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_MAX=30

# Gmail
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Google OAuth
GOOGLE_CLIENT_ID=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# VNPay Sandbox (ĐÃ SỬA: Xóa bỏ hoàn toàn phần chữ tiếng Việt thừa ở cuối hàng)
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
